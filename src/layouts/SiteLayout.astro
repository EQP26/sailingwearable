---
const { title = "High-Performance Sailing Biometric Wearable" } = Astro.props;
---
<!doctype html>
<html lang="pt">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <style>
      :root{
        --bg:#0b0f14;
        --panel:#0f1621;
        --text:#e9eef7;
        --muted:#a9b4c6;
        --line:rgba(255,255,255,.10);
        --accent:#6aa9ff;
        --accent2:#6affc3;
        --shadow: 0 10px 30px rgba(0,0,0,.35);
        --radius: 16px;
        --max: 1100px;
      }

      *{box-sizing:border-box}
      html{scroll-behavior:smooth}

      body{
        margin:0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Apple Color Emoji","Segoe UI Emoji";
        background: radial-gradient(1200px 600px at 50% -10%, rgba(106,169,255,.25), transparent 55%),
                    radial-gradient(900px 600px at 10% 30%, rgba(106,255,195,.12), transparent 60%),
                    var(--bg);
        color:var(--text);
      }

      a{color:inherit}
      .container{max-width:var(--max); margin:0 auto; padding:0 20px;}

      /* Navbar */
      .nav{
        position: sticky; top:0; z-index:50;
        backdrop-filter: blur(10px);
        background: rgba(11,15,20,.75);
        border-bottom:1px solid var(--line);
      }
      .nav-inner{
        display:flex; align-items:center; justify-content:space-between;
        height:64px;
      }
      .brand{
        display:flex; gap:10px; align-items:center; text-decoration:none;
        font-weight:700; letter-spacing:.3px;
        white-space:nowrap;
      }
      .brand span:last-child{
        font-size:13px;
        letter-spacing:.12em;
        text-transform:uppercase;
        color:var(--text);
        opacity:.95;
      }
      .dot{
        width:10px; height:10px; border-radius:999px;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        box-shadow: 0 0 0 6px rgba(106,169,255,.10);
      }

      .links{display:flex; gap:18px; align-items:center; flex-wrap:wrap;}
      .links a{
        text-decoration:none; font-size:13px; letter-spacing:.12em;
        color:var(--muted);
        padding:10px 10px;
        border-radius:10px;
      }
      .links a:hover{color:var(--text); background: rgba(255,255,255,.06)}

      /* Hero */
      .hero{padding:72px 0 28px;}
      .hero-card{
        border:1px solid var(--line);
        background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.02));
        border-radius: calc(var(--radius) + 8px);
        box-shadow: var(--shadow);
        padding:42px 28px;
        text-align:center;
      }
      .kicker{color:var(--muted); font-size:12px; letter-spacing:.22em;}
      h1{margin:12px 0 10px; font-size:42px; letter-spacing:.02em;}
      .subtitle{max-width:760px; margin:0 auto; color:var(--muted); line-height:1.65}
      .cta-row{display:flex; gap:12px; justify-content:center; margin-top:22px; flex-wrap:wrap;}

      .btn{
        display:inline-flex; align-items:center; justify-content:center;
        padding:11px 14px; border-radius:12px;
        text-decoration:none; font-weight:600; font-size:14px;
        border:1px solid var(--line);
        background: rgba(255,255,255,.04);
      }
      .btn.primary{
        border-color: transparent;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        color:#071018;
      }

      /* Sections */
      section{
        padding:38px 0;
        scroll-margin-top: 80px; /* para não ficar escondido atrás da navbar */
      }

      .section-title{display:flex; align-items:flex-end; justify-content:space-between; gap:12px}
      h2{margin:0; font-size:22px; letter-spacing:.08em}
      .hint{color:var(--muted); font-size:13px}

      .grid-2{display:grid; grid-template-columns: 1.2fr .8fr; gap:16px; margin-top:14px;}
      .grid-3{display:grid; grid-template-columns: repeat(3, 1fr); gap:16px; margin-top:14px;}

      .card{
        border:1px solid var(--line);
        background: rgba(255,255,255,.03);
        border-radius: var(--radius);
        padding:16px;
      }
      .card h3{margin:0 0 8px; font-size:14px; letter-spacing:.14em; color:var(--muted)}
      .card p{margin:0; color:var(--text); line-height:1.6}

      /* Team */
      .team-grid{display:grid; grid-template-columns: repeat(3, 1fr); gap:16px; margin-top:14px;}
      .person{display:flex; gap:14px; align-items:flex-start;}
      .avatar{
        width:52px; height:52px; border-radius:999px;
        background: linear-gradient(135deg, rgba(106,169,255,.35), rgba(106,255,195,.22));
        border:1px solid var(--line);
        flex:0 0 auto;
      }
      .person b{display:block; margin-bottom:4px}
      .meta{color:var(--muted); font-size:13px}

      /* Blog cards */
      .blog-grid{display:grid; grid-template-columns: repeat(4, 1fr); gap:16px; margin-top:14px;}
      .post{
        cursor:pointer;
        transition: transform .08s ease, background .08s ease, border-color .08s ease;
      }
      .post:hover{transform: translateY(-2px); background: rgba(255,255,255,.05); border-color: rgba(255,255,255,.18)}
      .thumb{
        width:100%; height:110px; border-radius:12px;
        background: linear-gradient(135deg, rgba(106,169,255,.25), rgba(106,255,195,.18));
        border:1px solid var(--line);
        margin-bottom:12px;
      }
      .post-title{font-weight:800; letter-spacing:.12em; font-size:14px}
      .post-date{color:var(--muted); font-size:12px; margin-top:6px}
      .post-excerpt{color:var(--muted); font-size:13px; margin-top:10px; line-height:1.55}

      /* Modal */
      dialog{
        width:min(760px, 92vw);
        border:none; border-radius: 18px;
        padding:0;
        background: rgba(15,22,33,.98);
        color:var(--text);
        box-shadow: 0 20px 70px rgba(0,0,0,.6);
      }
      dialog::backdrop{background: rgba(0,0,0,.65)}
      .modal-head{
        padding:18px 18px 12px;
        border-bottom:1px solid var(--line);
        display:flex; justify-content:space-between; gap:12px; align-items:center;
      }
      .modal-body{padding:18px; color:var(--muted); line-height:1.7}
      .x{
        border:1px solid var(--line);
        background: rgba(255,255,255,.04);
        color:var(--text);
        border-radius: 12px;
        padding:8px 12px;
        cursor:pointer;
        font-size:18px;
        line-height:1;
      }

      footer{
        padding:28px 0 40px;
        border-top:1px solid var(--line);
        color:var(--muted);
      }

      /* Responsive */
      @media (max-width: 980px){
        .grid-2{grid-template-columns:1fr}
        .grid-3{grid-template-columns:1fr}
        .team-grid{grid-template-columns:1fr}
        .blog-grid{grid-template-columns: repeat(2, 1fr)}
        h1{font-size:34px}
        .brand span:last-child{display:none;} /* em mobile fica só "ELECTROCAP" */
      }
      @media (max-width: 520px){
        .links{gap:6px}
        .links a{padding:8px 8px; letter-spacing:.10em}
        .blog-grid{grid-template-columns:1fr}
      }
    </style>
  </head>

  <body>
    <header class="nav">
      <div class="container nav-inner">
        <!-- marca curta + título curto -->
        <a class="brand" href="/#top" aria-label="Topo">
          <span class="dot" aria-hidden="true"></span>
          <span>High-Performance Sailing Biometric Wearable</span>
          <span>High-Performance Sailing Biometric Wearable</span>
        </a>

        <!-- links com "/#..." funcionam mesmo que estejas noutra rota -->
        <nav class="links" aria-label="Navegação">
          <a href="/#about">ABOUT</a>
          <a href="/#team">TEAM</a>
          <a href="/#video">VIDEO</a>
          <a href="/#blog">BLOG</a>
          <a href="/#partners">PARTNERS</a>
          <a href="/#contact">CONTACT</a>
        </nav>
      </div>
    </header>

    <main id="top">
      <slot />
    </main>

    <dialog id="postModal" aria-labelledby="modalTitle">
      <div class="modal-head">
        <div>
          <div id="modalTitle" style="font-weight:900; letter-spacing:.12em;"></div>
          <div id="modalDate" class="hint" style="margin-top:6px;"></div>
        </div>
        <button class="x" id="modalClose" aria-label="Fechar">×</button>
      </div>
      <div class="modal-body" id="modalBody"></div>
    </dialog>

    <script>
      const modal = document.getElementById("postModal");
      const t = document.getElementById("modalTitle");
      const d = document.getElementById("modalDate");
      const b = document.getElementById("modalBody");
      const closeBtn = document.getElementById("modalClose");

      closeBtn.addEventListener("click", () => modal.close());

      // fechar com ESC (alguns browsers já fazem, isto reforça)
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && modal.open) modal.close();
      });

      document.addEventListener("click", (e) => {
        const card = e.target.closest("[data-post]");
        if (!card) return;

        t.textContent = card.getAttribute("data-title") || "POST";
        d.textContent = card.getAttribute("data-date") || "";
        b.textContent = card.getAttribute("data-body") || "";
        modal.showModal();
      });
    </script>
  </body>
</html>
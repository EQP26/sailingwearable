---
import SiteLayout from "../layouts/SiteLayout.astro";

const projectTagline = "High-Performance Sailing Biometric Wearable";

const posts = [
  {
    title: "WEEK 1",
    date: "2026-03-01",
    excerpt: "Primeiras decisões do projeto.",
    body: "Resumo curto: setup inicial, requisitos, divisão de tarefas e primeiras decisões (sensores, arquitetura, plano de testes)."
  },
  {
    title: "WEEK 2",
    date: "2026-03-08",
    excerpt: "Escolha de sensores.",
    body: "Resumo curto: seleção preliminar de sensores biométricos e IMU, critérios (precisão, robustez, consumo), e próximos passos."
  }
];
---

<SiteLayout title={`Knotix — ${projectTagline}`}>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" integrity="sha512-9usAa10IRO0HhonpyAIVpjrylPvoDwiPUiKdWk5t3PyolY1cOd4DSE0Ga+ri4AuTroPR5aQvXU9xC6qOPnzFeg==" crossorigin="anonymous" referrerpolicy="no-referrer" />

  <header class="site-header">
    <div class="header-container">
      <a href="/" class="site-logo">Knotix</a>
      <nav class="main-nav">
        <ul>
          <li><a href="#about"><i class="fas fa-info-circle"></i> About</a></li>
          <li><a href="#team"><i class="fas fa-users"></i> Team</a></li>
          <li><a href="#video"><i class="fas fa-video"></i> Video</a></li>
          <li><a href="#blog"><i class="fas fa-bold"></i> Blog</a></li>
          <li><a href="#partners"><i class="fas fa-handshake"></i> Partners</a></li>
          <li><a href="#contact"><i class="fas fa-envelope"></i> Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <div class="container hero">
    <div class="hero-card">
      <div class="kicker">AN ELECTROCAP PROJECT</div>
      <h1>KNOTIX</h1>

      <p class="subtitle">
        Sistema wearable para atletas de vela que mede esforço físico e performance técnica em tempo real.
      </p>

      <div class="cta-row">
        <a class="btn primary" href="/proposta-electrocap.pdf" target="_blank" rel="noreferrer">PROPOSTA (PDF)</a>
        <a class="btn" href="/#blog">VER BLOG</a>
        <a class="btn" href="/#contact">CONTACTO</a>
      </div>
    </div>
  </div>

  <section id="about">
    <div class="container">
      <div class="section-title">
        <h2>ABOUT OUR PROJECT</h2>
        <div class="hint">Visão geral</div>
      </div>

      <div class="grid-2">
        <div class="card">
          <h3>PROBLEMA</h3>
          <p>
            Treinadores e atletas não têm dados contínuos e integrados sobre stress físico (fadiga, HRV, etc.)
            e performance técnica (postura, micro-ajustes) durante treino/competição.
          </p>
        </div>

        <div class="card">
          <h3>SOLUÇÃO</h3>
          <p>
            Wearable com sensores biométricos e IMU (acel/gyro), comunicação sem fios e packaging resistente à água,
            permitindo análise em tempo real e correlação entre esforço e manobras.
          </p>
        </div>
      </div>

      <div class="grid-3">
        <div class="card">
          <h3>BENEFICIÁRIOS</h3>
          <p>Atletas de vela competitiva, treinadores e investigação em ciência do desporto.</p>
        </div>
        <div class="card">
          <h3>AMBIENTE</h3>
          <p>Barcos pequenos / alta intensidade onde a contribuição física do atleta é crítica.</p>
        </div>
        <div class="card">
          <h3>SUCESSO</h3>
          <p>Precisão, resposta em tempo real e melhoria mensurável de performance.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="team">
    <div class="container">
      <div class="section-title">
        <h2>MEET THE TEAM</h2>
      </div>

      <div class="team-grid-new">
        <div class="card person-card">
          <div class="person-img" style="background-image: url('https://via.placeholder.com/100x120');"></div>
          <div class="person-info">
            <h3>DIOGO CANDEIAS</h3>
            <div class="course-id">LEE IST-ID 110584</div>
            <div class="major">3rd Year Electronics Engineering</div>
            <div class="person-links">
              <a href="mailto:email-do-diogo@tecnico.ulisboa.pt" class="btn-small"><i class="fas fa-envelope"></i> Email</a>
              <a href="#" class="btn-small"><i class="fab fa-linkedin"></i> LinkedIn</a>
            </div>
          </div>
        </div>

        <div class="card person-card">
          <div class="person-img" style="background-image: url('https://via.placeholder.com/100x120');"></div>
          <div class="person-info">
            <h3>MIGUEL DUARTE</h3>
            <div class="course-id">LEE IST-ID 110218</div>
            <div class="major">3rd Year Electronics Engineering</div>
            <div class="person-links">
              <a href="mailto:email-do-miguel@tecnico.ulisboa.pt" class="btn-small"><i class="fas fa-envelope"></i> Email</a>
              <a href="#" class="btn-small"><i class="fab fa-linkedin"></i> LinkedIn</a>
            </div>
          </div>
        </div>

        <div class="card person-card">
          <div class="person-img" style="background-image: url('https://via.placeholder.com/100x120');"></div>
          <div class="person-info">
            <h3>HUGO CHEN</h3>
            <div class="course-id">LEEC IST-ID 109566</div>
            <div class="major">3rd Year Electrical and Computer Engineering</div>
            <div class="person-links">
              <a href="mailto:email-do-hugo@tecnico.ulisboa.pt" class="btn-small"><i class="fas fa-envelope"></i> Email</a>
              <a href="#" class="btn-small"><i class="fab fa-linkedin"></i> LinkedIn</a>
            </div>
          </div>
        </div>

        <div class="card person-card">
          <div class="person-img" style="background-image: url('https://via.placeholder.com/100x120');"></div>
          <div class="person-info">
            <h3>GONÇALO LOPES</h3>
            <div class="course-id">LEE IST-ID 111160</div>
            <div class="major">3rd Year Electronics Engineering</div>
            <div class="person-links">
              <a href="mailto:email-do-goncalo@tecnico.ulisboa.pt" class="btn-small"><i class="fas fa-envelope"></i> Email</a>
              <a href="#" class="btn-small"><i class="fab fa-linkedin"></i> LinkedIn</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="video">
    <div class="container">
      <div class="section-title">
        <h2>VIDEO</h2>
        <div class="hint">Demo / apresentação</div>
      </div>

      <div class="card">
        <p style="margin:0; color: var(--muted);">
          Placeholder — quando tiverem vídeo, coloquem aqui o embed (YouTube/Drive).
        </p>
      </div>
    </div>
  </section>

  <section id="blog">
    <div class="container">
      <div class="section-title">
        <h2>BLOG</h2>
        <div class="hint">Clica num cartão para abrir</div>
      </div>

      <div class="blog-grid">
        {posts.map((p) => (
          <div
            class="card post"
            data-post
            data-title={p.title}
            data-date={p.date}
            data-body={p.body}
            role="button"
            tabIndex="0"
          >
            <div class="thumb" aria-hidden="true"></div>
            <div class="post-title">{p.title}</div>
            <div class="post-date">{p.date}</div>
            <div class="post-excerpt">{p.excerpt}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="partners">
    <div class="container">
      <div class="section-title">
        <h2>PARTNERS</h2>
        <div class="hint">Placeholders</div>
      </div>

      <div class="grid-3">
        <div class="card" style="display:flex; align-items:center; justify-content:center; min-height:90px; color:var(--muted); letter-spacing:.08em;">
          Parceiro A
        </div>
        <div class="card" style="display:flex; align-items:center; justify-content:center; min-height:90px; color:var(--muted); letter-spacing:.08em;">
          Parceiro B
        </div>
        <div class="card" style="display:flex; align-items:center; justify-content:center; min-height:

---
import SiteLayout from "../layouts/SiteLayout.astro";

const projectTagline = "High-Performance Sailing Biometric Wearable";

const posts = [
  {
    title: "WEEK 1",
    date: "AAAA-MM-DD",
    excerpt: "Primeiras decisões do projeto.",
    body: "Resumo curto: setup inicial, requisitos, divisão de tarefas e primeiras decisões (sensores, arquitetura, plano de testes)."
  },
  {
    title: "WEEK 2",
    date: "AAAA-MM-DD",
    excerpt: "Escolha de sensores.",
    body: "Resumo curto: seleção preliminar de sensores biométricos e IMU, critérios (precisão, robustez, consumo), e próximos passos."
  }
];
---

<SiteLayout title={`${projectTagline} — ElectroCap`}>
  <div class="container hero">
    <div class="hero-card">
      <div class="kicker">{projectTagline}</div>
      <h1>ELECTROCAP</h1>

      <p class="subtitle">
        Sistema wearable para atletas de vela que mede esforço físico e performance técnica em tempo real.
      </p>

      <div class="cta-row">
        <a class="btn primary" href="/proposta-electrocap.pdf" target="_blank" rel="noreferrer">PROPOSTA (PDF)</a>
        <a class="btn" href="/#blog">VER BLOG</a>
        <a class="btn" href="/#contact">CONTACTO</a>
      </div>
    </div>
  </div>

  <!-- ABOUT -->
  <section id="about">
    <div class="container">
      <div class="section-title">
        <h2>ABOUT OUR PROJECT</h2>
        <div class="hint">Visão geral</div>
      </div>

      <div class="grid-2">
        <div class="card">
          <h3>PROBLEMA</h3>
          <p>
            Treinadores e atletas não têm dados contínuos e integrados sobre stress físico (fadiga, HRV, etc.)
            e performance técnica (postura, micro-ajustes) durante treino/competição.
          </p>
        </div>

        <div class="card">
          <h3>SOLUÇÃO</h3>
          <p>
            Wearable com sensores biométricos e IMU (acel/gyro), comunicação sem fios e packaging resistente à água,
            permitindo análise em tempo real e correlação entre esforço e manobras.
          </p>
        </div>
      </div>

      <div class="grid-3">
        <div class="card">
          <h3>BENEFICIÁRIOS</h3>
          <p>Atletas de vela competitiva, treinadores e investigação em ciência do desporto.</p>
        </div>
        <div class="card">
          <h3>AMBIENTE</h3>
          <p>Barcos pequenos / alta intensidade onde a contribuição física do atleta é crítica.</p>
        </div>
        <div class="card">
          <h3>SUCESSO</h3>
          <p>Precisão, resposta em tempo real e melhoria mensurável de performance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section id="team">
    <div class="container">
      <div class="section-title">
        <h2>TEAM</h2>
        <div class="hint">Membros &amp; funções</div>
      </div>

      <div class="team-grid">
        <div class="card person">
          <div class="avatar" aria-hidden="true"></div>
          <div>
            <b>Membro 1</b>
            <div class="meta">Função</div>
          </div>
        </div>

        <div class="card person">
          <div class="avatar" aria-hidden="true"></div>
          <div>
            <b>Membro 2</b>
            <div class="meta">Função</div>
          </div>
        </div>

        <div class="card person">
          <div class="avatar" aria-hidden="true"></div>
          <div>
            <b>Membro 3</b>
            <div class="meta">Função</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VIDEO (para o link do menu funcionar) -->
  <section id="video">
    <div class="container">
      <div class="section-title">
        <h2>VIDEO</h2>
        <div class="hint">Demo / apresentação</div>
      </div>

      <div class="card">
        <p style="margin:0; color: var(--muted);">
          Placeholder — quando tiverem vídeo, coloquem aqui o embed (YouTube/Drive).
        </p>
      </div>
    </div>
  </section>

  <!-- BLOG -->
  <section id="blog">
    <div class="container">
      <div class="section-title">
        <h2>BLOG</h2>
        <div class="hint">Clica num cartão para abrir</div>
      </div>

      <div class="blog-grid">
        {posts.map((p) => (
          <div
            class="card post"
            data-post
            data-title={p.title}
            data-date={p.date}
            data-body={p.body}
            role="button"
            tabIndex="0"
          >
            <div class="thumb" aria-hidden="true"></div>
            <div class="post-title">{p.title}</div>
            <div class="post-date">{p.date}</div>
            <div class="post-excerpt">{p.excerpt}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PARTNERS (para o link do menu funcionar) -->
  <section id="partners">
    <div class="container">
      <div class="section-title">
        <h2>PARTNERS</h2>
        <div class="hint">Placeholders</div>
      </div>

      <div class="grid-3">
        <div class="card" style="display:flex; align-items:center; justify-content:center; min-height:90px; color:var(--muted); letter-spacing:.08em;">
          Parceiro A
        </div>
        <div class="card" style="display:flex; align-items:center; justify-content:center; min-height:90px; color:var(--muted); letter-spacing:.08em;">
          Parceiro B
        </div>
        <div class="card" style="display:flex; align-items:center; justify-content:center; min-height:90px; color:var(--muted); letter-spacing:.08em;">
          Parceiro C
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact">
    <div class="container">
      <div class="section-title">
        <h2>CONTACT</h2>
        <div class="hint">Email</div>
      </div>

      <div class="grid-2">
        <div class="card">
          <h3>EMAIL</h3>
          <p>equipa.electrocap@tecnico.ulisboa.pt</p>
        </div>
        <div class="card">
          <h3>LINKS</h3>
          <p>
            <a href="/proposta-electrocap.pdf" style="color:var(--accent)" target="_blank" rel="noreferrer">Proposta (PDF)</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
<style is:global>
  /* Cores Principais do ElectroCap */
  :root {
    --bg-color: #f4f7f6;
    --text-color: #333333;
    --accent: #0f2c59; /* Azul Escuro Náutico */
    --muted: #7f8c8d;
    --card-bg: #ffffff;
  }

  body {
    font-family: 'Segoe UI', Roboto, Helvetica, sans-serif;
    background-color: var(--bg-color);
    color: var(--text-color);
    line-height: 1.6;
    margin: 0;
    padding: 0;
  }

  /* Centrar e limitar o tamanho da página */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  section {
    padding: 40px 0;
    border-bottom: 1px solid #e1e8ed;
  }

  h1, h2, h3 { color: var(--accent); }

  /* --- CABEÇALHO PRINCIPAL (HERO) --- */
  .hero-card {
    background: linear-gradient(135deg, #0f2c59 0%, #1a4989 100%);
    color: white;
    padding: 60px 40px;
    border-radius: 16px;
    text-align: center;
    box-shadow: 0 10px 30px rgba(15, 44, 89, 0.2);
    margin-top: 20px;
  }
  .hero-card h1 {
    color: white;
    font-size: 3.5em;
    margin: 10px 0;
    letter-spacing: 3px;
  }
  .hero-card .subtitle {
    font-size: 1.2em;
    margin-bottom: 30px;
    opacity: 0.9;
  }
  .hero-card .kicker {
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.9em;
    color: #a8c6fa;
  }

  /* --- BOTÕES --- */
  .cta-row {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
  }
  .btn {
    background-color: rgba(255,255,255,0.15);
    color: white;
    text-decoration: none;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: bold;
    transition: 0.3s;
  }
  .btn:hover { background-color: rgba(255,255,255,0.3); }
  .btn.primary {
    background-color: white;
    color: var(--accent);
  }
  .btn.primary:hover { background-color: #f0f0f0; }

  /* --- TÍTULOS DAS SECÇÕES --- */
  .section-title {
    text-align: center;
    margin-bottom: 40px;
  }
  .section-title h2 {
    margin-bottom: 5px;
    font-size: 2.2em;
  }
  .section-title .hint {
    color: var(--accent);
    text-transform: uppercase;
    font-size: 0.85em;
    font-weight: bold;
    letter-spacing: 1px;
  }

  /* --- CARTÕES (CARDS) --- */
  .card {
    background: var(--card-bg);
    padding: 25px;
    border-radius: 12px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.04);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 20px rgba(0,0,0,0.08);
  }
  .card h3 { margin-top: 0; }

  /* --- GRELHAS (GRIDS) --- */
  .grid-2 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 25px;
    margin-bottom: 25px;
  }
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 25px;
  }
  .team-grid, .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 25px;
  }

  /* --- FOTOS DE EQUIPA E BLOG --- */
  .avatar {
    background-color: #e0e6ed;
    height: 100px;
    width: 100px;
    border-radius: 50%;
    margin: 0 auto 15px auto;
  }
  .thumb {
    background-color: #e0e6ed;
    height: 160px;
    border-radius: 8px;
    margin-bottom: 15px;
  }
  .card.person { text-align: center; }
  .meta { color: var(--muted); font-size: 0.9em; }
  
  /* Blog Textos */
  .post-title { font-weight: bold; font-size: 1.3em; color: var(--accent); }
  .post-date { font-size: 0.85em; color: var(--muted); margin-bottom: 10px; }
  .post-excerpt { color: var(--text-color); font-size: 0.95em; }

  /* Deslizar suavemente ao clicar nos botões */
  html { scroll-behavior: smooth; }
</style>

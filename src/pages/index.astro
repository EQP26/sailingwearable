---
import SiteLayout from "../layouts/SiteLayout.astro";

const projectTagline = "High-Performance Sailing Biometric Wearable";

const posts = [
  {
    title: "WEEK 1",
    date: "2026-03-01",
    excerpt: "Project Kick-off and Initial Technical Decisions.",
    body: "In our first week, we established the project roadmap, defined core requirements for marine environments, and distributed tasks among the team."
  },
  {
    title: "WEEK 2",
    date: "2026-03-08",
    excerpt: "Sensor Selection and Hardware Architecture.",
    body: "Benchmarking sensors: evaluating IMUs for wave-motion compensation and biometric sensors for salt-water reliability."
  }
];
---

<SiteLayout title={`Knotix — ${projectTagline}`}>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

  <header class="site-header">
    <div class="header-container">
      <a href="#top" class="site-logo">Knotix</a>
      <nav class="main-nav">
        <ul>
          <li><a href="#about">About</a></li>
          <li><a href="#team">Team</a></li>
          <li><a href="#blog">Blog</a></li>
          <li><a href="#partners">Partners</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <section id="top" class="hero-minimal">
    <div class="container">
      <div class="hero-content">
        <div class="kicker">An ElectroCap Project</div>
        <h1>KNOTIX</h1>
        <p>A cutting-edge wearable system for sailing athletes designed to synchronize biometric effort with technical performance in real-time.</p>
        <div class="cta-simple">
          <a class="btn-ghost" href="#blog">View Updates</a>
          <a class="btn-ghost" href="#about">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <section id="about">
    <div class="container">
      <div class="section-title">
        <h2>About our Project</h2>
        <div class="hint">Technical Overview</div>
      </div>

      <div class="grid-2">
        <div class="card-tech">
          <h3>The Problem</h3>
          <p>Competitive sailing lacks integrated, real-time feedback systems. Athletes cannot correlate physical fatigue with specific technical maneuvers.</p>
        </div>
        <div class="card-tech">
          <h3>Our Solution</h3>
          <p>Knotix bridges this gap with a rugged, water-resistant wearable combining high-precision IMU data with biometric sensors.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="team">
    <div class="container">
      <div class="section-title">
        <h2>Meet the Team</h2>
      </div>

      <div class="team-grid-new">
        <div class="card person-card">
          <div class="person-img" style="background-image: url('/sailingwearable/Diogo.jpeg');"></div>
          <div class="person-info">
            <h3>DIOGO CANDEIAS</h3>
            <div class="course-id">LEE IST-ID 110584</div>
            <div class="major">3rd Year Electronics Engineering</div>
            <div class="person-links">
              <a href="mailto:diogo.candeias@tecnico.ulisboa.pt" class="btn-small">Email</a>
            </div>
          </div>
        </div>

        <div class="card person-card">
          <div class="person-img" style="background-image: url('/sailingwearable/Miguel.jpeg');"></div>
          <div class="person-info">
            <h3>MIGUEL DUARTE</h3>
            <div class="course-id">LEE IST-ID 110218</div>
            <div class="major">3rd Year Electronics Engineering</div>
            <div class="person-links">
              <a href="mailto:miguel.duarte@tecnico.ulisboa.pt" class="btn-small">Email</a>
              <a href="#" target="_blank" class="btn-small"><i class="fab fa-linkedin"></i></a>
            </div>
          </div>
        </div>

        <div class="card person-card">
          <div class="person-img" style="background-image: url('/sailingwearable/Hugo.jpeg');"></div>
          <div class="person-info">
            <h3>HUGO CHEN</h3>
            <div class="course-id">LEEC IST-ID 109566</div>
            <div class="major">3rd Year Electrical and Computer Engineering</div>
            <div class="person-links">
              <a href="mailto:hugo.chen@tecnico.ulisboa.pt" class="btn-small">Email</a>
            </div>
          </div>
        </div>

        <div class="card person-card">
          <div class="person-img" style="background-image: url('/sailingwearable/Goncalo.jpeg');"></div>
          <div class="person-info">
            <h3>GONÇALO LOPES</h3>
            <div class="course-id">LEE IST-ID 111160</div>
            <div class="major">3rd Year Electronics Engineering</div>
            <div class="person-links">
              <a href="mailto:goncalo.lopes@tecnico.ulisboa.pt" class="btn-small">Email</a>
              <a href="#" target="_blank" class="btn-small"><i class="fab fa-linkedin"></i></a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="blog">
    <div class="container">
      <div class="section-title"><h2>Blog</h2><div class="hint">Weekly Progress</div></div>
      <div class="blog-grid">
        {posts.map((p) => (
          <div class="card post" data-post data-title={p.title} data-date={p.date} data-body={p.body}>
            <div class="post-title">{p.title}</div>
            <div class="post-date">{p.date}</div>
            <div class="post-excerpt">{p.excerpt}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="partners">
    <div class="container">
      <div class="section-title"><h2>Partners</h2></div>
      <div class="grid-3">
        <div class="partner-box">Partner A</div>
        <div class="partner-box">Partner B</div>
        <div class="partner-box">Partner C</div>
      </div>
    </div>
  </section>

  <footer class="main-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <span class="footer-logo">Knotix</span>
          <p>High-performance biometric monitoring for elite sailing.</p>
        </div>
        <div class="footer-nav">
          <h4>Navigation</h4>
          <ul>
            <li><a href="#about">Project</a></li>
            <li><a href="#team">Team</a></li>
            <li><a href="#blog">Blog</a></li>
          </ul>
        </div>
        <div class="footer-contact" id="contact">
          <h4>Contact</h4>
          <p>equipa.electrocap@tecnico.ulisboa.pt</p>
          <div class="footer-socials">
            <a href="#"><i class="fab fa-github"></i></a>
            <a href="#"><i class="fab fa-linkedin"></i></a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Knotix. An ElectroCap Project.</p>
      </div>
    </div>
  </footer>

  <a href="#top" id="backToTop"><i class="fas fa-chevron-up"></i></a>

<style is:global>
  :root {
    --bg-color: #ffffff;
    --text-color: #1d1d1f;
    --accent: #054a91;
    --muted: #86868b;
    --footer-bg: #111111;
  }

  * { box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background-color: var(--bg-color); color: var(--text-color); margin: 0; }
  html { scroll-behavior: smooth; }
  .container { max-width: 1000px; margin: 0 auto; padding: 0 20px; }
  section { padding: 80px 0; }

  /* HEADER */
  .site-header { position: sticky; top: 0; background: rgba(255,255,255,0.8); backdrop-filter: blur(20px); z-index: 1000; border-bottom: 1px solid #f2f2f2; }
  .header-container { height: 60px; display: flex; justify-content: space-between; align-items: center; }
  .site-logo { font-weight: 800; text-decoration: none; color: var(--accent); font-size: 1.2em; letter-spacing: 1px; }
  .main-nav ul { list-style: none; display: flex; gap: 20px; padding: 0; }
  .main-nav a { text-decoration: none; color: var(--text-color); font-size: 0.9em; font-weight: 500; }

  /* NOVO HERO MINIMALISTA */
  .hero-minimal { padding: 120px 0 80px; text-align: center; background: radial-gradient(circle at top, #f0f4f8 0%, #ffffff 100%); }
  .hero-content h1 { font-size: 5em; font-weight: 900; margin: 10px 0; letter-spacing: -2px; color: var(--accent); }
  .kicker { font-weight: 700; color: var(--muted); text-transform: uppercase; font-size: 0.8em; letter-spacing: 2px; }
  .hero-minimal p { font-size: 1.4em; color: var(--muted); max-width: 600px; margin: 20px auto 40px; line-height: 1.4; }
  .cta-simple { display: flex; justify-content: center; gap: 20px; }
  .btn-ghost { padding: 12px 24px; border: 1.5px solid var(--accent); color: var(--accent); text-decoration: none; border-radius: 30px; font-weight: 600; transition: 0.3s; }
  .btn-ghost:hover { background: var(--accent); color: white; }

  /* ABOUT & CARDS */
  .section-title { margin-bottom: 40px; text-align: center; }
  .section-title h2 { font-size: 2.5em; font-weight: 800; margin: 0; }
  .hint { color: var(--accent); font-weight: 700; text-transform: uppercase; font-size: 0.7em; letter-spacing: 1.5px; }
  .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }
  .card-tech { padding: 30px; background: #fbfbfd; border-radius: 18px; }
  .card-tech h3 { margin-top: 0; color: var(--accent); }

  /* TEAM */
  .team-grid-new { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; }
  .person-card { text-align: center; padding: 20px; }
  .person-img { width: 120px; height: 120px; border-radius: 50%; margin: 0 auto 15px; background-size: cover; border: 4px solid #f2f2f2; }
  .person-info h3 { font-size: 1.1em; margin: 0; font-weight: 800; }
  .course-id { font-size: 0.75em; font-weight: 700; color: var(--muted); }
  .major { font-size: 0.75em; color: var(--muted); margin: 8px 0 15px; }
  .person-links { display: flex; justify-content: center; gap: 10px; }
  .btn-small { text-decoration: none; color: var(--text-color); border: 1px solid #ddd; padding: 4px 12px; border-radius: 6px; font-size: 0.8em; font-weight: 600; }

  /* FOOTER PROFISSIONAL */
  .main-footer { background: var(--footer-bg); color: white; padding: 60px 0 30px; margin-top: 60px; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 40px; margin-bottom: 40px; }
  .footer-logo { font-size: 1.5em; font-weight: 900; color: var(--accent); display: block; margin-bottom: 10px; }
  .footer-brand p { color: #888; font-size: 0.9em; }
  .footer-nav h4, .footer-contact h4 { font-size: 0.9em; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px; color: #fff; }
  .footer-nav ul { list-style: none; padding: 0; }
  .footer-nav a { color: #888; text-decoration: none; font-size: 0.9em; line-height: 2.5; }
  .footer-contact p { color: #888; font-size: 0.9em; }
  .footer-socials { margin-top: 15px; display: flex; gap: 15px; }
  .footer-socials a { color: #fff; font-size: 1.2em; }
  .footer-bottom { border-top: 1px solid #222; padding-top: 20px; text-align: center; color: #555; font-size: 0.8em; }

  /* BACK TO TOP */
  #backToTop { position: fixed; bottom: 20px; right: 20px; background: var(--accent); color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none; opacity: 0; transition: 0.3s; z-index: 1000; }
  #backToTop.show { opacity: 1; }

  .partner-box { background: #f9f9f9; height: 80px; display: flex; align-items: center; justify-content: center; border-radius: 12px; color: #ccc; font-weight: 700; border: 1px solid #eee; }
  .post-title { font-weight: 800; font-size: 1.1em; }
  .post-date { font-size: 0.8em; color: var(--accent); font-weight: 700; }
</style>

<script is:inline>
  window.onscroll = function() {
    const btn = document.getElementById("backToTop");
    if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
      btn.classList.add("show");
    } else {
      btn.classList.remove("show");
    }
  };
</script>
</SiteLayout>
